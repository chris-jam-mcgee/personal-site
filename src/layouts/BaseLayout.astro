---
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { sortItemsByDateDesc } from '../utils/data-utils';
import { Image } from 'astro:assets';
import mountain from './mountain-light.png';
import mountainDark from './mountain-dark.png';
import smaug from './smaug.png';

export type Props = HeadProps & { showHeader?: boolean };

const { showHeader = true, ...head } = Astro.props;
---

<html lang="en" class="antialiased break-words">
    <head>
        <BaseHead {...head} />
        <script>
            if (localStorage.theme === 'dark') {
                document.documentElement.classList.add('dark');
            }
        </script>
        <ClientRouter />
    </head>
    <body class="bg-main text-main relative">
        <div class="flex flex-col min-h-screen px-4 md:px-8">
            <main class="grow w-full mx-auto grid grid-cols-5 gap-8 px-8">
                <div class="h-full">
                    <div class="sticky top-0 py-8 h-screen flex flex-col justify-between">
                        <Hero />

                        <div class:list={['pt-6 flex flex-col gap-4 border-t border-dashed border-main']}>
                            <p class="text-sm">
                                &copy; {new Date().getFullYear()}&nbsp;. All rights reserved.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="py-8 col-span-3">
                    <slot />
                </div>

                <div class="h-full">
                    <div class="sticky top-0 py-8 h-screen flex flex-col justify-between items-stretch">
                        <div class="flex flex-row justify-end">
                            <ThemeToggle />
                        </div>
                        <div class="relative w-full">
                            <Image src={smaug} alt="A scary dragon" class="absolute" />
                            <Image src={mountain} alt="A pretty mountain" class="block dark:hidden" />
                            <Image src={mountainDark} alt="A pretty mountain" class="hidden dark:block" />
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </body>
</html>
